{
  "name": "@nitrosend/ai-sdk",
  "version": "0.4.0",
  "description": "Vercel AI SDK tools for Nitrosend, backed by the remote Nitrosend MCP server",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:schemas": "node scripts/generate-schemas.mjs",
    "check:schemas": "node scripts/check-schema-count.mjs",
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "node --test --import tsx 'src/**/*.test.ts'",
    "prepack": "npm run generate:schemas && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/mcp": "^1.0.0",
    "ai": "^7.0.0-0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/mcp": "^1.0.39",
    "@types/node": "^22",
    "ai": "^7.0.0-beta",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "ai",
    "vercel",
    "ai-sdk",
    "mcp",
    "tools",
    "nitrosend",
    "email",
    "marketing"
  ],
  "homepage": "https://nitrosend.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/nitrosend/nitrosend"
  }
}
